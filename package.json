    "test:unit:coverage": "sfdx-lwc-jest --coverage -- --passWithNoTests"
  },
  "devDependencies": {
    "@salesforce/sfdx-lwc-jest": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
