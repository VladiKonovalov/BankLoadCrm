{
  "name": "bank-crm",
  "private": true,
  "version": "1.0.0",
  "description": "Bank CRM Salesforce DX project — LWC Jest tooling",
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "sfdx-lwc-jest -- --passWithNoTests",
